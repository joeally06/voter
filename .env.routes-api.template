# ============================================
# Google Maps API Configuration
# ============================================

# Main API Key (used as fallback)
GOOGLE_MAPS_API_KEY=your_main_api_key_here

# Geocoding API Key (separate quota tracking)
GOOGLE_MAPS_GEOCODING_API_KEY=your_geocoding_api_key_here

# Routes API Key (NEW - for migration)
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: https://console.cloud.google.com/apis/library/routes.googleapis.com
GOOGLE_MAPS_ROUTES_API_KEY=your_routes_api_key_here

# Legacy Distance Matrix API Key (DEPRECATED - remove after migration)
# Keep for rollback capability during migration period
# GOOGLE_MAPS_DISTANCE_MATRIX_API_KEY=your_old_key_here

# ============================================
# Routes API Feature Flag
# ============================================

# Set to "true" to use Routes API, "false" for legacy Distance Matrix API
# Migration: Start with "false" to test, then switch to "true" when ready
USE_ROUTES_API=false

# ============================================
# Routes API Configuration (Advanced)
# ============================================

# Routes API endpoint (default: production)
# No need to change unless using a different environment
# ROUTES_API_ENDPOINT=https://routes.googleapis.com/distanceMatrix/v2:computeRouteMatrix

# Routes API timeout (milliseconds)
# Default: 10000 (10 seconds)
# ROUTES_API_TIMEOUT_MS=10000

# Routes API routing preference
# Options: TRAFFIC_UNAWARE (default, cheaper) or TRAFFIC_AWARE (more accurate with traffic data)
# Note: TRAFFIC_AWARE increases API costs (Pro tier vs Essentials tier)
ROUTES_API_ROUTING_PREFERENCE=TRAFFIC_UNAWARE

# Routes API field mask (comma-separated, no spaces)
# Default includes minimal fields for cost optimization
# Do not modify unless you need additional fields
# Available fields: originIndex,destinationIndex,duration,distanceMeters,status,condition,travelAdvisory
ROUTES_API_FIELD_MASK=originIndex,destinationIndex,duration,distanceMeters,status,condition

# ============================================
# Rate Limiting Configuration
# ============================================

# Rate limit for Distance Matrix / Routes API (queries per second)
# Routes API default: 50 EPS (3,000 elements per minute limit)
# Legacy Distance Matrix default: 10 EPS
# Adjust based on your quota and subscription tier
DISTANCE_MATRIX_RATE_LIMIT=50

# Minimum delay between API calls (milliseconds)
# Default: 100ms (pairs with rate limit above)
DISTANCE_MATRIX_DELAY_MS=100

# ============================================
# Progressive Routing Configuration
# ============================================

# Enable progressive routing (lazy-loading of distances)
# Reduces API calls by 94-96% via sparse matrix
# Recommended: true (keep enabled)
PROGRESSIVE_ROUTING_ENABLED=true

# ============================================
# Route Cache Configuration
# ============================================

# Cache TTL in days
# How long to keep cached route data before re-fetching
ROUTE_CACHE_TTL_DAYS=30

# Enable route caching
# Caches distance/duration data in SQLite to reduce API calls
CACHE_ROUTES=true

# ============================================
# Migration Notes
# ============================================

# Step 1: Enable Routes API in Google Cloud Console
#   - Visit: https://console.cloud.google.com/apis/library/routes.googleapis.com
#   - Click "Enable"
#
# Step 2: Generate/update API key
#   - Visit: https://console.cloud.google.com/apis/credentials
#   - Create new key or use existing GOOGLE_MAPS_API_KEY
#   - Restrict to "Routes API" for security (recommended)
#
# Step 3: Test with USE_ROUTES_API=false first
#   - Verify legacy Distance Matrix API still works
#   - Confirm rollback capability
#
# Step 4: Switch to USE_ROUTES_API=true
#   - Monitor error logs
#   - Check API quota usage in Google Cloud Console
#   - Verify route calculations work correctly
#
# Step 5: Optimize (after successful migration)
#   - Test TRAFFIC_AWARE routing if needed
#   - Adjust rate limits based on usage patterns
#   - Monitor costs and optimize field mask if necessary
#
# Rollback: If issues occur, immediately set USE_ROUTES_API=false and restart

