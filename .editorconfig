# ============================================================================
# Voter Outreach & Mapping Platform - Editor Configuration
# ============================================================================
# EditorConfig helps maintain consistent coding styles across different
# editors and IDEs. See https://editorconfig.org for more information.
# ============================================================================

# Top-most EditorConfig file
root = true

# ============================================================================
# All Files
# ============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================================
# JavaScript and Node.js Files
# ============================================================================
[*.{js,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

[backend/**/*.js]
# Backend uses 4-space indentation for consistency with existing code
indent_size = 4

[frontend/**/*.js]
# Frontend uses 2-space indentation
indent_size = 2

# ============================================================================
# JSON Files
# ============================================================================
[*.json]
indent_style = space
indent_size = 2

[package.json]
indent_size = 2

# ============================================================================
# Markdown Files
# ============================================================================
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# ============================================================================
# HTML Files
# ============================================================================
[*.html]
indent_style = space
indent_size = 2

# ============================================================================
# CSS Files
# ============================================================================
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# ============================================================================
# Configuration Files
# ============================================================================
[{.babelrc,.eslintrc,.prettierrc,.stylelintrc}]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

# ============================================================================
# Environment Files
# ============================================================================
[.env*]
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================================
# Shell Scripts
# ============================================================================
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# ============================================================================
# Batch Files (Windows)
# ============================================================================
[*.{bat,cmd}]
end_of_line = crlf

# ============================================================================
# Makefiles
# ============================================================================
[Makefile]
indent_style = tab

# ============================================================================
# SQL Files
# ============================================================================
[*.sql]
indent_style = space
indent_size = 2
