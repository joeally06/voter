# ============================================================================
# Voter Outreach & Mapping Platform - Git Ignore Configuration
# ============================================================================

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ============================================================================
# Environment Files
# ============================================================================
# IMPORTANT: .env contains sensitive data and should NEVER be committed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# DO NOT IGNORE: .env.example should be tracked in version control
!.env.example

# ============================================================================
# Database Files
# ============================================================================
# Exclude all SQLite database files
data/*.db
data/*.sqlite
data/*.db-shm
data/*.db-wal

# Keep directory structure but ignore contents
data/backups/*
!data/backups/.gitkeep

data/cache/*
!data/cache/.gitkeep

data/processed/*
!data/processed/.gitkeep

# Exclude all uploaded raw data files (CSV, DBF, Excel, etc.)
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

# ============================================================================
# Logs
# ============================================================================
logs/*.log
logs/*.log.*

# Keep logs directory
!logs/.gitkeep

# ============================================================================
# Runtime Data
# ============================================================================
pids/
*.pid
*.seed
*.pid.lock

# ============================================================================
# OS Generated Files
# ============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================================
# IDE and Editor Files
# ============================================================================
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (WebStorm, PHPStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*.swn
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================================
# Build Outputs
# ============================================================================
dist/
build/
out/
*.tsbuildinfo

# ============================================================================
# Test Coverage
# ============================================================================
coverage/
.nyc_output/
*.lcov

# ============================================================================
# Temporary Files
# ============================================================================
temp/
tmp/
*.tmp
*.temp
tmpclaude-*

# ============================================================================
# Project-Specific Exclusions
# ============================================================================
# Exclude specific data files
election.pdf
LEWIS - DIST. 2.csv

# ============================================================================
# Optional: Uncomment if using these tools
# ============================================================================
# .eslintcache
# .stylelintcache
# .npm
# .yarn-integrity
