# ============================================================================
# VOTER OUTREACH & MAPPING PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env` in the root directory
# 2. Update all CRITICAL variables marked with [CRITICAL]
# 3. Review and customize OPTIONAL variables as needed
# 4. NEVER commit your `.env` file to version control
#
# For deployment help, see: docs/DEPLOYMENT.md
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# [CRITICAL] Node environment: development, production, or test
NODE_ENV=development

# [CRITICAL] Port number for the Express server
# Default: 3000
PORT=3000

# [CRITICAL] Host address for the server
# Use 'localhost' for local development, '0.0.0.0' for Docker/production
HOST=localhost

# ============================================================================
# GOOGLE MAPS API CONFIGURATION
# ============================================================================

# [CRITICAL] Google Maps JavaScript API Key for frontend map display
# Required for: Map visualization, marker clustering, route planning
# Get your API key: https://console.cloud.google.com/google/maps-apis
# Required APIs: Maps JavaScript API, Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# [CRITICAL] Google Maps Geocoding API Key for backend address geocoding
# Required for: Converting voter addresses to latitude/longitude coordinates
# Get your API key: https://console.cloud.google.com/google/maps-apis
# Required APIs: Geocoding API
# Note: Can be the same key as GOOGLE_MAPS_API_KEY or a separate restricted key
GOOGLE_MAPS_GEOCODING_API_KEY=your_geocoding_api_key_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# [CRITICAL] Path to SQLite database file
# The database stores voter records, geocoding cache, and system data
DB_PATH=./data/voter_platform.db

# [OPTIONAL] Directory for automatic database backups
# Backups are created before bulk operations and data imports
DB_BACKUP_PATH=./data/backups/

# [OPTIONAL] How many days to retain database backups
BACKUP_RETENTION_DAYS=30

# ============================================================================
# GEOCODING CONFIGURATION
# ============================================================================

# [OPTIONAL] Maximum geocoding requests per second to Google Maps API
# Prevents rate limit violations. Adjust based on your API tier.
# Default: 10 requests/second (well within Google's 50 req/sec limit)
GEOCODING_RATE_LIMIT=10

# [OPTIONAL] Number of addresses to process in each geocoding batch
# Larger batches = faster processing, but higher memory usage
# Default: 100
GEOCODING_BATCH_SIZE=100

# [OPTIONAL] Delay in milliseconds between individual geocoding requests
# Helps prevent rate limiting and API throttling
# Default: 100ms
GEOCODING_DELAY_MS=100

# [OPTIONAL] Daily quota limit for geocoding API calls
# Google provides 40,000 free requests per month (~1,333/day)
# Adjust based on your API billing plan
# Default: 10000
DAILY_QUOTA_LIMIT=10000

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# [CRITICAL] Secret key for session encryption
# REQUIRED: Generate a strong random string for production
# Example: Use `openssl rand -base64 32` to generate a secure key
SESSION_SECRET=your_session_secret_here_change_in_production

# [OPTIONAL] Allowed CORS origin for API requests
# Set to your frontend URL in production (e.g., https://yourdomain.com)
# Use comma-separated list for multiple origins
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# [OPTIONAL] Logging verbosity level
# Options: error, warn, info, verbose, debug
# Default: info
LOG_LEVEL=info

# [OPTIONAL] Path to application log file
# Logs are rotated automatically when they exceed 10MB
LOG_FILE=./logs/app.log

# ============================================================================
# DATA PROCESSING CONFIGURATION
# ============================================================================

# [OPTIONAL] Maximum file size for voter data imports
# Supports: KB, MB, GB (e.g., 100MB, 1GB)
# Default: 100MB
MAX_IMPORT_FILE_SIZE=100MB

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# [OPTIONAL] Enable caching of geocoding results
# Dramatically speeds up re-processing of same addresses
# Default: true
CACHE_GEOCODING_RESULTS=true

# [OPTIONAL] Number of days to keep cached geocoding results
# Addresses don't change often, so 90 days is recommended
# Default: 90
CACHE_TTL_DAYS=90

# ============================================================================
# FEATURE TOGGLES
# ============================================================================

# [OPTIONAL] Enable route planning feature for canvassing
# Requires: GOOGLE_MAPS_API_KEY with Directions API enabled
# Default: true
ENABLE_ROUTE_PLANNING=true

# ============================================================================
# ROUTE OPTIMIZATION CONFIGURATION
# ============================================================================

# [OPTIONAL] Enable progressive routing optimization
# Reduces Distance Matrix API calls by 94-96% through lazy loading
# For 50 voters: 2,500 → 90-150 API calls
# Default: true (recommended for cost savings)
PROGRESSIVE_ROUTING=true

# [OPTIONAL] Google Maps Distance Matrix API Key
# Required for: Route optimization and distance calculations
# Can be the same as GOOGLE_MAPS_GEOCODING_API_KEY or a separate key
# Get your API key: https://console.cloud.google.com/google/maps-apis
# Required APIs: Distance Matrix API
GOOGLE_MAPS_DISTANCE_MATRIX_API_KEY=your_distance_matrix_api_key_here

# [OPTIONAL] Distance Matrix API rate limit (requests per second)
# Default: 10 requests/second (adjust based on your API tier)
DISTANCE_MATRIX_RATE_LIMIT=10

# [OPTIONAL] Delay between Distance Matrix API requests (milliseconds)
# Default: 100ms
DISTANCE_MATRIX_DELAY_MS=100

# ============================================================================
# REMAINING FEATURE TOGGLES
# ============================================================================

# [OPTIONAL] Enable data export functionality (CSV, JSON)
# Default: true
ENABLE_DATA_EXPORT=true

# [OPTIONAL] Enable analytics dashboard and charts
# Default: true
ENABLE_ANALYTICS=true

# ============================================================================
# MAP PERFORMANCE CONFIGURATION
# ============================================================================

# [OPTIONAL] Enable marker clustering on the map
# Improves performance when displaying thousands of voters
# Default: true
MAP_MARKER_CLUSTERING=true

# [OPTIONAL] Maximum number of markers to display before forcing clustering
# Default: 1000
MAX_MARKERS_WITHOUT_CLUSTERING=1000

# ============================================================================
# FRONTEND APPLICATION CONFIGURATION
# ============================================================================

# [OPTIONAL] Application version displayed in footer
# Default: 4.0.0
APP_VERSION=4.0.0

# ============================================================================
# GEOGRAPHIC SETTINGS
# ============================================================================

# [OPTIONAL] Display name for your geographic region
# Shown in UI headers and page titles
# Default: Obion County, TN
LOCATION_NAME=Obion County, TN

# [OPTIONAL] Default map center latitude (decimal degrees)
# Default: 36.2639 (Obion County, TN)
MAP_CENTER_LAT=36.2639

# [OPTIONAL] Default map center longitude (decimal degrees)
# Default: -89.1929 (Obion County, TN)
MAP_CENTER_LNG=-89.1929

# [OPTIONAL] Initial zoom level when map loads
# Range: 1 (world) to 20 (building level)
# Default: 11 (county level)
MAP_DEFAULT_ZOOM=11

# [OPTIONAL] Maximum zoom level when auto-fitting markers
# Default: 16 (street level)
MAP_MAX_AUTO_ZOOM=16

# ============================================================================
# ORGANIZATION SETTINGS
# ============================================================================

# [OPTIONAL] Organization name displayed in UI
# Default: Obion County Election Commission
ORGANIZATION_NAME=Obion County Election Commission

# [OPTIONAL] Copyright year displayed in footer
# Default: 2026
COPYRIGHT_YEAR=2026

# ============================================================================
# MAP DISPLAY CONFIGURATION
# ============================================================================

# [OPTIONAL] Minimum number of markers before clustering activates
# Default: 100
MARKER_CLUSTER_THRESHOLD=100

# [OPTIONAL] Clustering radius in pixels
# Markers within this radius are grouped into clusters
# Default: 100
CLUSTER_RADIUS=100

# [OPTIONAL] Map marker color for "Super Voters" (high participation)
# Hex color code. Default: #198754 (Bootstrap green)
MARKER_COLOR_SUPER=#198754

# [OPTIONAL] Map marker color for regular voters
# Hex color code. Default: #6c757d (Bootstrap secondary gray)
MARKER_COLOR_REGULAR=#6c757d

# ============================================================================
# FRONTEND PERFORMANCE CONFIGURATION
# ============================================================================

# [OPTIONAL] Cache timeout for frontend data in milliseconds
# Default: 300000 (5 minutes)
CACHE_TIMEOUT_MS=300000

# [OPTIONAL] Maximum number of cached items in frontend
# Default: 50
MAX_CACHE_SIZE=50

# [OPTIONAL] Default number of records per page in tables
# Default: 1000
DEFAULT_PAGE_SIZE=1000

# ============================================================================
# UPLOAD CONFIGURATION
# ============================================================================

# [OPTIONAL] Maximum upload file size in bytes
# Default: 104857600 (100MB)
MAX_UPLOAD_SIZE_BYTES=104857600

# [OPTIONAL] Minimum polling interval for upload status (milliseconds)
# Default: 1000 (1 second)
UPLOAD_POLL_MIN_MS=1000

# [OPTIONAL] Maximum polling interval for upload status (milliseconds)
# Default: 10000 (10 seconds)
UPLOAD_POLL_MAX_MS=10000

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# [OPTIONAL] Maximum number of retry attempts for failed API requests
# Default: 3
MAX_RETRY_ATTEMPTS=3

# ============================================================================
# CHART CONFIGURATION
# ============================================================================

# [OPTIONAL] Color palette for analytics charts (JSON array format)
# Colors should be hex codes in a JSON array string
# Default: Bootstrap color scheme
CHART_COLORS=["#0d6efd","#198754","#dc3545","#ffc107","#0dcaf0","#6c757d","#6f42c1","#fd7e14","#20c997","#d63384"]