{
  "name": "voter-outreach-platform",
  "version": "1.0.0",
  "description": "Local voter outreach and mapping platform for Obion County Election Commission data",
  "main": "backend/server.js",
  "scripts": {
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "prestart": "npm run build:frontend && powershell -ExecutionPolicy Bypass -File scripts/cleanup-port.ps1",
    "start": "node backend/server.js",
    "start:backend": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest",
    "setup": "node scripts/setup.js",
    "doctor": "node scripts/doctor.js",
    "health": "node backend/scripts/health-check.js",
    "import-data": "node scripts/import-dbf.js",
    "geocode": "node scripts/batch-geocode.js",
    "restart": "npm run prestart && npm start"
  },
  "keywords": [
    "voter",
    "outreach",
    "mapping",
    "election",
    "geocoding"
  ],
  "author": "Your Name",
  "license": "Private",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "axios": "^1.6.2",
    "bottleneck": "^2.19.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "shapefile": "^0.6.6",
    "sqlite3": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/jest": "^29.5.8",
    "autoprefixer": "^10.4.24",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
